<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="459.0" prefWidth="381.0" spacing="5.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ee.ivkhkdev.javafxpro1.JavaFxPro1Controller">
   <HBox fx:id="hbUsername" prefHeight="21.0" prefWidth="361.0">
      <children>
         <Label fx:id="lbUsername" alignment="CENTER_RIGHT" prefHeight="17.0" prefWidth="135.0" text="Username:">
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin>
         </Label>

         <TextField fx:id="tfUserName" alignment="CENTER" prefHeight="25.0" prefWidth="251.0" />
      </children>
      <padding>
         <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
      </padding>
   </HBox>
   <HBox fx:id="hbPassword" prefHeight="18.0" prefWidth="361.0">
      <children>
         <Label fx:id="lbPassword" alignment="CENTER_RIGHT" prefHeight="17.0" prefWidth="135.0" text="Password">
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin>
         </Label>
         <TextField fx:id="tfPassword" alignment="CENTER" prefHeight="25.0" prefWidth="251.0" />
      </children>
   </HBox>
    <Label fx:id="label" text="Привет, мир!">
      <VBox.margin>
         <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
      </VBox.margin></Label>
   <HBox fx:id="hbButtons" prefHeight="18.0" prefWidth="361.0" alignment="CENTER" >
      <children>
         <Button fx:id="btnService" onAction="#btnServiceClick" text="Добавить элемент" />
         <Button fx:id="btnDelete" onAction="#btnDeleteClick" text="Удалить элемент" />
      </children>
   </HBox>

   <ListView fx:id="lvUserList" prefHeight="200.0" prefWidth="200.0">
      <VBox.margin>
         <Insets top="10.0" />
      </VBox.margin>
   </ListView>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
